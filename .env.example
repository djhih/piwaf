# ── PiWAF 設定範本 ────────────────────────────────────────────
# clone 後執行：cp .env.example .env，再依環境調整。
#
# BunkerWeb 版本（multi-arch，Raspberry Pi arm64 可用）
BW_VERSION=1.6.1

# WAF 模式（對應計畫的 Detection / Blocking Mode）
#   On            → Blocking Mode（實際阻擋，回 403）
#   DetectionOnly → Detection Mode（只記錄，不擋，仍回 200）
#   Off           → 完全不檢查
WAF_MODE=On

# CRS 異常分數門檻（CRS 預設 5；用來標記 would_block）
ANOMALY_THRESHOLD=5

# 對外埠綁定介面（鎖區網用）。
#   空值        = 綁所有介面(0.0.0.0，含 VPN/外網介面，較不安全)
#   <LAN_IP>:   = 只綁該介面（注意結尾要有冒號），把服務限制在那個子網
# ⚠ 建議填你這台的 LAN IP（例 192.168.1.50:）以免暴露到 VPN/外網。
BIND_ADDR=

# 對外埠（若 80 被佔可改）
BW_HTTP_PORT=8080       # 經過 WAF 的入口
APP_DIRECT_PORT=3001    # Direct Mode：直接打測試站（繞過 WAF）
DASHBOARD_PORT=8501     # Streamlit 儀表板
